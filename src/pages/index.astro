---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="c0redumpsec — security research, tooling, writeups, and experiments."
    />
    <title>c0redumpsec</title>
  </head>

  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="c0redumpsec home">
        <img
          src="/assets/img/c0redumpsec-logo-green-wide.png"
          alt="c0redumpsec"
          class="logo"
        />
      </a>

      <nav class="nav" aria-label="Main navigation">
        <a href="/">Blog</a>
        <a href="/about">About</a>
        <a href="https://github.com/c0redumpsec">GitHub</a>
      </nav>
    </header>

    <main class="page">
      <section class="intro">
	<h1 class="terminal-title" aria-label="$ Tales from the terminal.">
  		<span id="terminal-title-text"></span><span class="terminal-cursor">|</span>
	</h1>

	<script>
  		const text = '$ Tales from the terminal.';
  		const target = document.getElementById('terminal-title-text');

  		if (target) {
    			let index = 0;

    			const type = () => {
      			target.textContent = text.slice(0, index);
      			index += 1;

      			if (index <= text.length) {
        			window.setTimeout(type, 65);
      			}	
    		};

    		window.setTimeout(type, 350);
  		}
	</script>
        <p class="tagline">
          Security research, tooling, writeups, and lessons learned the hard way.
        </p>
      </section>
      <section class="posts" aria-labelledby="latest-posts">
  <h2 id="latest-posts">Latest posts</h2>

  {
    posts.length > 0 ? (
      <div class="post-list">
        {posts.map((post) => {
          const slug = post.id.replace(/\.(md|mdx)$/, '');

          return (
            <article class="post-card">
              <p class="post-date">
                {post.data.pubDate.toLocaleDateString('en-GB', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>

              <h3>
                <a href={`/blog/${slug}/`}>{post.data.title}</a>
              </h3>

              <p>{post.data.description}</p>
            </article>
          );
        })}
      </div>
    ) : (
      <p>No posts published yet.</p>
    )
  }
</section>
    </main>
  </body>
</html>
