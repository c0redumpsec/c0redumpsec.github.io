---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="About c0redumpsec — security research, technical notes, tooling, and writeups."
    />
    <title>About | c0redumpsec</title>
  </head>

  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="c0redumpsec home">
        <img
          src="/assets/img/c0redumpsec-logo-green.png"
          alt="c0redumpsec"
          class="logo"
        />
      </a>

      <nav class="nav" aria-label="Main navigation">
        <a href="/">Blog</a>
        <a href="/about">About</a>
        <a href="https://github.com/c0redumpsec">GitHub</a>
      </nav>
    </header>

    <main class="page">
      <a href="/" class="back">← Back to blog</a>

      <section class="card">
        <h1>About c0redumpsec</h1>

        <p>
          c0redumpsec is a place for security research, practical notes, tooling
          experiments, lab writeups, and technical learning.
        </p>

        <p>
          This site will eventually include writeups, security labs, tool notes,
          project documentation, and lessons learned from hands-on research.
        </p>

        <p>
          More details, contact information, disclosure notes, and areas of focus
          can be added here later.
        </p>
      </section>
    </main>
  </body>
</html>
