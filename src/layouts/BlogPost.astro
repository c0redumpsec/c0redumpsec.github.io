---
import PageLayout from './PageLayout.astro';

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
} = Astro.props;
---

<PageLayout title={title} description={description}>
  <article class="markdown-content">
    <p class="section-label">Post</p>

    <h1>{title}</h1>

    <p class="post-date">
      {pubDate.toLocaleDateString('en-GB', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}

      {
        updatedDate && (
          <>
            {' '}
            · updated{' '}
            {updatedDate.toLocaleDateString('en-GB', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </>
        )
      }
    </p>

    {
      tags.length > 0 && (
        <ul class="tag-list">
          {tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }

    <slot />
  </article>
</PageLayout>
